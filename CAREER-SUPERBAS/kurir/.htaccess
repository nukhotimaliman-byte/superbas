<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Cache Strategy ─────────────────────────────
# CSS/JS: cache 1 year (use ?v=X.X query for busting)
<FilesMatch "\.(css|js)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

# HTML: always revalidate (user gets fresh content)
<FilesMatch "\.(html)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, must-revalidate"
    </IfModule>
</FilesMatch>

# Images & Fonts: cache 30 days
<FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|woff2|woff|ttf)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=2592000"
    </IfModule>
</FilesMatch>

# PHP API: never cache
<FilesMatch "\.php$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </IfModule>
</FilesMatch>

# Deny access to config
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</Files>

# Deny access to SQL, MD, and sensitive files
<FilesMatch "\.(sql|md|sqlite)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Deny directory listing
Options -Indexes

# Protect uploads — only allow image/pdf access
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/uploads/
    RewriteCond %{REQUEST_URI} !\.(jpg|jpeg|png|pdf)$ [NC]
    RewriteRule .* - [F,L]
</IfModule>
